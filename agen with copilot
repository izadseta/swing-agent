# ───────────────────────────────────────────────────────────────
# COOLDOWN MEMORY (NEW)
# Prevents duplicate alerts unless price moves 3% or MACD flips
# ───────────────────────────────────────────────────────────────
COOLDOWN_FILE = "cooldown.json"

def load_cooldown():
    if not os.path.exists(COOLDOWN_FILE):
        return {}
    try:
        with open(COOLDOWN_FILE, "r") as f:
            return json.load(f)
    except:
        return {}

def save_cooldown(data):
    with open(COOLDOWN_FILE, "w") as f:
        json.dump(data, f, indent=2)

cooldown_data = load_cooldown()

def cooldown_triggered(ticker, signal):
    if ticker not in cooldown_data:
        return False

    prev = cooldown_data[ticker]
    old_price = prev["price"]
    new_price = signal["price"]

    price_change = abs(new_price - old_price) / old_price * 100
    macd_changed = prev["macd"] != signal["macd_crossover"]

    return price_change < 3 and not macd_changed

def update_cooldown(ticker, signal):
    cooldown_data[ticker] = {
        "price": signal["price"],
        "macd": signal["macd_crossover"],
        "timestamp": datetime.now().isoformat()
    }
    save_cooldown(cooldown_data)

# ───────────────────────────────────────────────────────────────
# MARKET DATA
# ───────────────────────────────────────────────────────────────
def fetch_stock_data(ticker: str, period: str = "3mo") -> pd.DataFrame:
    df = yf.download(ticker, period=period, interval="1d", progress=False)
    if df.empty:
        return df

    if isinstance(df.columns, pd.MultiIndex):
        df.columns = df.columns.get_level_values(0)

    close = df["Close"]
    high = df["High"]
    low = df["Low"]

    df["RSI"] = ta.momentum.RSIIndicator(close, window=14).rsi()

    bb = ta.volatility.BollingerBands(close, window=20)
    df["BBU_20"] = bb.bollinger_hband()
    df["BBL_20"] = bb.bollinger_lband()
    df["BBM_20"] = bb.bollinger_mavg()

    df["ATR"] = ta.volatility.AverageTrueRange(high, low, close, window=14).average_true_range()

    macd = ta.trend.MACD(close)
    df["MACD_12_26_9"] = macd.macd()
    df["MACDs_12_26_9"] = macd.macd_signal()

    df["Vol_Avg20"] = df["Volume"].rolling(20).mean()
    df["Vol_Spike"] = df["Volume"] / df["Vol_Avg20"]

    return df.dropna()

# ───────────────────────────────────────────────────────────────
# SIGNAL SUMMARY
# ───────────────────────────────────────────────────────────────
def build_signal_summary(ticker: str, df: pd.DataFrame) -> dict:
    if df.empty or len(df) < 5:
        return {}

    last = df.iloc[-1]
    prev = df.iloc[-2]

    price = float(last["Close"])
    price_change_5d = (price - float(df.iloc[-5]["Close"])) / float(df.iloc[-5]["Close"]) * 100

    macd_val = float(last["MACD_12_26_9"])
    macd_sig = float(last["MACDs_12_26_9"])
    prev_macd = float(prev["MACD_12_26_9"])
    prev_sig = float(prev["MACDs_12_26_9"])

    if macd_val > macd_sig and prev_macd <= prev_sig:
        crossover = "bullish"
    elif macd_val < macd_sig and prev_macd >= prev_sig:
        crossover = "bearish"
    else:
        crossover = "none"

    return {
        "ticker": ticker,
        "price": round(price, 2),
        "price_change_5d_pct": round(price_change_5d, 2),
        "RSI": round(float(last["RSI"]), 1),
        "ATR": round(float(last["ATR"]), 2),
        "ATR_pct_of_price": round(float(last["ATR"]) / price * 100, 2),
        "volume_spike_ratio": round(float(last["Vol_Spike"]), 2),
        "bb_upper": round(float(last["BBU_20"]), 2),
        "bb_lower": round(float(last["BBL_20"]), 2),
        "bb_mid": round(float(last["BBM_20"]), 2),
        "price_vs_bb": (
            "above_upper" if price > float(last["BBU_20"]) else
            "below_lower" if price < float(last["BBL_20"]) else
            "inside_bands"
        ),
        "macd": round(macd_val, 4),
        "macd_signal": round(macd_sig, 4),
        "macd_crossover": crossover,
        "as_of": str(df.index[-1].date()),
    }

# ───────────────────────────────────────────────────────────────
# CLAUDE ANALYSIS (with timeout + safe JSON)
# ───────────────────────────────────────────────────────────────
SYSTEM_PROMPT = """You are a disciplined swing trade analyst..."""

def analyze_with_claude(signal: dict) -> dict:
    client = Anthropic(api_key=ANTHROPIC_API_KEY)

    prompt = f"""Analyze this swing trade setup and return JSON only:

{json.dumps(signal, indent=2)}

Stop-loss guideline: ~{STOP_LOSS_PCT}%
Take-profit guideline: ~{TAKE_PROFIT_PCT}%
Only flag HIGH conviction if 3+ signals align."""

    try:
        response = client.messages.create(
            model="claude-3-5-sonnet-latest",
            max_tokens=600,
            system=SYSTEM_PROMPT,
            messages=[{"role": "user", "content": prompt}],
            timeout=12
        )
        raw = response.content[0].text.strip()

        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            logging.error(f"Bad JSON from Claude for {signal['ticker']}: {raw}")
            return {"action": "NO_ACTION", "conviction": "LOW", "reasoning": "Invalid JSON"}

    except Exception as e:
        logging.error(f"Claude timeout/error: {e}")
        return {"action": "NO_ACTION", "conviction": "LOW", "reasoning": "LLM unavailable"}

# ───────────────────────────────────────────────────────────────
# TELEGRAM
# ───────────────────────────────────────────────────────────────
def send_telegram(message: str):
    if not TELEGRAM_BOT_TOKEN or not TELEGRAM_CHAT_ID:
        return False

    url = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage"
    r = requests.post(url, json={
        "chat_id": TELEGRAM_CHAT_ID,
        "text": message,
        "parse_mode": "HTML"
    })
    return r.ok

# ───────────────────────────────────────────────────────────────
# ALERT FORMAT
# ───────────────────────────────────────────────────────────────
def format_alert(signal: dict, decision: dict) -> str:
    ticker = signal["ticker"]
    action = decision["action"]
    conviction = decision["conviction"]
    price = signal["price"]

    if action == "BUY_ALERT":
        emoji = "🟢"
        action_text = "BUY ALERT"
    elif action == "SELL_ALERT":
        emoji = "🔴"
        action_text = "SELL / EXIT ALERT"
    else:
        return ""

    entry = decision.get("entry_price") or price
    sl = decision.get("stop_loss") or round(price * (1 - STOP_LOSS_PCT / 100), 2)
    tp = decision.get("take_profit") or round(price * (1 + TAKE_PROFIT_PCT / 100), 2)

    rr = round((tp - entry) / (entry - sl), 1) if entry != sl else "N/A"

    return (
        f"{emoji} <b>{action_text} — {ticker}</b> [{conviction}]\n\n"
        f"<b>Price:</b> ${price}  |  <b>As of:</b> {signal['as_of']}\n"
        f"<b>Entry:</b> ~${entry}\n"
        f"<b>Stop-loss:</b> ${sl}\n"
        f"<b>Take-profit:</b> ${tp}\n"
        f"<b>Risk/Reward:</b> 1:{rr}\n\n"
        f"<b>Why:</b> {decision['reasoning']}\n\n"
        f"<b>Signals:</b> {' · '.join(decision.get('key_signals', []))}\n\n"
        f"<i>RSI {signal['RSI']} · ATR {signal['ATR']} ({signal['ATR_pct_of_price']}%) · "
        f"Vol spike {signal['volume_spike_ratio']}x · {signal['price_vs_bb']}</i>\n\n"
        f"⚠️ <i>Manual execution required.</i>"
    )

# ───────────────────────────────────────────────────────────────
# BACKTEST MODE (NEW)
# ───────────────────────────────────────────────────────────────
def backtest(ticker, days=90):
    df = yf.download(ticker, period=f"{days}d", interval="1d", progress=False)
    if df.empty:
        return None

    df["RSI"] = ta.momentum.RSIIndicator(df["Close"]).rsi()
    df["BBL"] = ta.volatility.BollingerBands(df["Close"]).bollinger_lband()

    df["signal"] = (
        (df["RSI"] < 40) &
        (df["Close"] <= df["BBL"])
    )

    entries = df[df["signal"]]
    return len(entries)

# ───────────────────────────────────────────────────────────────
# MAIN SCAN
# ───────────────────────────────────────────────────────────────
def run_scan():
    logging.info("Starting scan")

    alerts_sent = 0

    for ticker in WATCHLIST:
        try:
            df = fetch_stock_data(ticker)
            if df.empty:
                continue

            signal = build_signal_summary(ticker, df)
            if not signal:
                continue

            if cooldown_triggered(ticker, signal):
                logging.info(f"Cooldown active for {ticker}, skipping.")
                continue

            decision = analyze_with_claude(signal)
            action = decision.get("action", "NO_ACTION")
            conviction = decision.get("conviction", "LOW")

            if action != "NO_ACTION" and conviction in ("HIGH", "MEDIUM"):
                msg = format_alert(signal, decision)
                if msg:
                    send_telegram(msg)
                    alerts_sent += 1
                    update_cooldown(ticker, signal)

        except Exception as e:
            logging.error(f"Error on {ticker}: {e}")

    logging.info(f"Scan complete. Alerts sent: {alerts_sent}")

# ───────────────────────────────────────────────────────────────
# ENTRY POINT
# ───────────────────────────────────────────────────────────────
if __name__ == "__main__":
    run_scan()
